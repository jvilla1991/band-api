# Copy this file to .env and fill in real values. Never commit .env.

# Database
DB_URL=jdbc:postgresql://localhost:5432/banddb
DB_USERNAME=
DB_PASSWORD=

# Admin seed — set both to create the initial admin user on first startup
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JWT — generate a random string of at least 32 characters
JWT_SECRET=

# CORS — comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_SUCCESS_URL=http://localhost:5173/shop/success
STRIPE_CANCEL_URL=http://localhost:5173/shop
