# Copy this file to .env and fill in real values. Never commit .env.

# Database
DB_URL=jdbc:postgresql://localhost:5432/banddb
DB_USERNAME=
DB_PASSWORD=

# Admin seed — set both to create the initial admin user on first startup
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JWT — generate a random string of at least 32 characters
JWT_SECRET=

# CORS — comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:5173

# Stripe (SPA is hash-routed; Stripe appends ?session_id=... to the success URL)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_SUCCESS_URL=http://localhost:5173/#/store/success
STRIPE_CANCEL_URL=http://localhost:5173/#/store

# Printify — print-on-demand fulfillment (catalog sync + order creation on hold)
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# Shop — flat-rate shipping (cents) and comma-separated ISO2 countries for Stripe's
# shipping address collection
# Fallback only — shipping is quoted live from Printify per cart
SHOP_SHIPPING_FALLBACK_CENTS=599
SHOP_ALLOWED_COUNTRIES=US

# YourArea community
# Frontend base URL the emailed magic links point at
MAGIC_LINK_BASE_URL=http://localhost:5173
# Official villxin account seed (magic-link login, no password)
OFFICIAL_EMAIL=
OFFICIAL_USERNAME=villxin
# Optional comma-separated word-filter blocklist override
# WORD_FILTER_BLOCKLIST=
